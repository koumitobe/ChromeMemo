{
  "manifest_version": 3,
  "name": "ChromeMemo",
  "version": "1.0.0",
  "description": "どのページでも使えるサイドバーメモ帳",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "storage/storage.js",
        "markdown/markdown.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ChromeMemoを開閉",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "mac": "Command+M",
        "default": "Alt+M"
      },
      "description": "ChromeMemoサイドバーを開閉する"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
